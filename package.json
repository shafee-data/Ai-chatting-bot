  "homepage": "https://github.com/your-username/AI-Website-Project",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/AI-Website-Project.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/AI-Website-Project/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {}
